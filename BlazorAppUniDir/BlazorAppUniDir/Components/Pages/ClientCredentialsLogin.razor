@page "/client-credentials"
@using Unidir.AuthenticationApi
@using Unidir.AuthenticationApi.Models
@using Microsoft.AspNetCore.WebUtilities

@rendermode InteractiveServer
@inject AuthenticationApiClient AuthClient
@inject IConfiguration Config

<h3>Client Credentials Grant</h3>

<p>Log in using a machine-to-machine flow without a user interface interacting.</p>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="LoginModel" OnValidSubmit="HandleLogin" FormName="ClientCredentialsForm">
            <div class="mb-3">
                <label class="form-label">Email (Client ID)</label>
                <InputText class="form-control" @bind-Value="LoginModel.ClientId" />
            </div>
            <div class="mb-3">
                <label class="form-label">Password (Client Secret)</label>
                <InputText type="password" class="form-control" @bind-Value="LoginModel.ClientSecret" />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span>Logging in...</span>
                }
                else
                {
                    <span>Get Token</span>
                }
            </button>
        </EditForm>
    </div>
</div>

@if (!string.IsNullOrEmpty(AccessToken))
{
    <div class="alert alert-success mt-4">
        <strong>Success! Access Token:</strong> <br />
        <small style="word-break: break-all;">@AccessToken</small>
    </div>
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger mt-4">
        <strong>Error:</strong> @ErrorMessage
    </div>
}

@code {
    public ClientCredentialsTokenRequest LoginModel { get; set; } = new ClientCredentialsTokenRequest
    {
        ClientId = "S3AQe0cfJZrKHeKcagyHZ4JgmMemW3Rm" // Default Client ID mapped
    };

    public string? AccessToken { get; set; }
    public string? ErrorMessage { get; set; }
    public bool IsLoading { get; set; }

    protected override void OnInitialized()
    {
        LoginModel.ClientId = Config["UnidirOAuth:ClientId"] ?? "";
    }

    private async Task HandleLogin()
    {
        IsLoading = true;
        ErrorMessage = null;
        AccessToken = null;

        try
        {
            var response = await AuthClient.GetTokenAsync(LoginModel);
            AccessToken = response.AccessToken;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
